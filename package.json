{
  "name": "@davidsneighbour/imagemin-lint-staged",
  "version": "1.0.0",
  "description": "imagemin CLI designed for lint-staged usage with sensible defaults",
  "license": "MIT",
  "maintainers": [
    {
      "name": "davidsneighbour",
      "email": "davidsneighbourdev+gh@gmail.com",
      "url": "https://github.com/davidsneighbour"
    }
  ],
  "author": {
    "name": "tomchentw",
    "email": "developer@tomchentw.com",
    "url": "https://github.com/tomchentw"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidsneighbour/imagemin-lint-staged.git"
  },
  "bugs": {
    "url": "https://github.com/davidsneighbour/imagemin-lint-staged/issues"
  },
  "homepage": "https://github.com/davidsneighbour/imagemin-lint-staged/",
  "bin": {
    "imagemin-lint-staged": "bin/index.js"
  },
  "files": [
    "bin/",
    "lib/",
    "CHANGELOG.md"
  ],
  "keywords": [
    "imagemin",
    "CLI",
    "git hook",
    "compress images",
    "lint-staged"
  ],
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "release": "release-it --ci"
  },
  "lint-staged": {
    "*.{png,jpeg,jpg,gif,svg}": [
      "node ./bin/index.js"
    ],
    "*.{js,jsx,json,css}": [
      "prettier --write"
    ]
  },
  "jest": {
    "testPathIgnorePatterns": [
      "\\d+\\.\\d+\\.\\d+"
    ]
  },
  "dependencies": {
    "@release-it/conventional-changelog": "11.0.0",
    "cosmiconfig": "9.0.1",
    "imagemin-gifsicle": "7.0.0",
    "imagemin-jpegtran": "8.0.0",
    "imagemin-optipng": "8.0.0",
    "imagemin-svgo": "12.0.0",
    "release-it": "20.0.1",
    "util.promisify": "1.1.3"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.5",
    "babel-jest": "30.4.1",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "rimraf": "6.1.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "type": "module"
}
